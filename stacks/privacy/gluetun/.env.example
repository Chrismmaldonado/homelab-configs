# Copy to .env. Do not commit .env.
# Mullvad WireGuard: https://mullvad.net/en/account/wireguard-config
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=your_private_key_here
WIREGUARD_ADDRESSES=10.x.x.x/32
SERVER_COUNTRIES=USA
# Optional: pin a city
# SERVER_CITIES=New York NY

# Gluetun HTTP proxy for testing (curl -x http://127.0.0.1:8888 https://am.i.mullvad.net/json)
HTTPPROXY=on
