@import url("https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&display=swap");

:root {
  --bg: #07090a;
  --panel: rgba(14, 20, 22, 0.9);
  --panel-hover: rgba(22, 32, 34, 0.98);
  --border: rgba(43, 255, 156, 0.12);
  --border-strong: rgba(43, 255, 156, 0.4);
  --text: #cdd6d4;
  --muted: #6c807e;
  --accent: #2bff9c;
  --glow: rgba(43, 255, 156, 0.2);
  --mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
}

html,
body {
  background: var(--bg) !important;
  color: var(--text) !important;
  font-family: var(--mono) !important;
  overflow: hidden !important;
  max-width: 100vw !important;
  max-height: 100vh !important;
  height: 100% !important;
}

#__next,
#page_wrapper,
#inner_wrapper {
  background: transparent !important;
  height: 100% !important;
  max-height: 100vh !important;
  overflow: hidden !important;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background:
    radial-gradient(ellipse 70% 45% at 50% -5%, rgba(43, 255, 156, 0.06), transparent 55%),
    linear-gradient(rgba(43, 255, 156, 0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(43, 255, 156, 0.025) 1px, transparent 1px);
  background-size: auto, 40px 40px, 40px 40px;
}

.container,
#information-widgets,
#layout-groups,
#footer {
  position: relative;
  z-index: 1;
}

.container {
  width: 100% !important;
  max-width: 1280px !important;
  height: 100% !important;
  max-height: 100vh !important;
  margin: 0 auto !important;
  padding: 0.55rem 0.85rem 0.4rem !important;
  box-sizing: border-box !important;
  display: flex !important;
  flex-direction: column !important;
  justify-content: flex-start !important;
  overflow: hidden !important;
}

/* compact top bar */
#information-widgets {
  margin: 0 0 0.45rem !important;
  flex: 0 0 auto !important;
}
#widgets-wrap {
  gap: 0.45rem !important;
}
.information-widget,
#widgets-wrap > div {
  background: var(--panel) !important;
  border: 1px solid var(--border) !important;
  border-radius: 8px !important;
  box-shadow: none !important;
  padding-top: 0.15rem !important;
  padding-bottom: 0.15rem !important;
  min-width: 0 !important;
  transform: scale(0.92);
  transform-origin: center left;
}
#search-input,
input[type="text"] {
  background: transparent !important;
  border: none !important;
  color: var(--text) !important;
  font-family: var(--mono) !important;
  font-size: 0.8rem !important;
}

#layout-groups {
  display: flex !important;
  flex-direction: column !important;
  flex: 1 1 auto !important;
  min-height: 0 !important;
  width: 100% !important;
  margin: 0 !important;
  overflow: hidden !important;
}

.services-group {
  width: 100% !important;
  min-width: 0 !important;
  flex: 1 1 auto !important;
  display: flex !important;
  flex-direction: column !important;
  min-height: 0 !important;
}

.service-group-name,
h2 {
  font-family: var(--mono) !important;
  font-size: 0.68rem !important;
  font-weight: 600 !important;
  letter-spacing: 0.16em !important;
  text-transform: uppercase !important;
  color: var(--muted) !important;
  margin: 0 0 0.4rem 0.05rem !important;
  flex: 0 0 auto !important;
}
.service-group-name::before {
  content: "";
  display: inline-block;
  width: 7px;
  height: 7px;
  margin-right: 0.45rem;
  border-radius: 2px;
  background: var(--accent);
  box-shadow: 0 0 8px var(--glow);
  vertical-align: 0.05em;
}

/* dense 5-column tile grid that fills remaining viewport */
.services-list {
  display: grid !important;
  grid-template-columns: repeat(5, minmax(0, 1fr)) !important;
  grid-auto-rows: 1fr !important;
  gap: 8px !important;
  width: 100% !important;
  flex: 1 1 auto !important;
  min-height: 0 !important;
  align-content: stretch !important;
}

.service-card {
  min-width: 0 !important;
  height: 100% !important;
  max-height: none !important;
  margin: 0 !important;
  padding: 0.35rem 0.4rem !important;
  background: var(--panel) !important;
  background-color: rgba(14, 20, 22, 0.9) !important;
  border: 1px solid var(--border) !important;
  border-radius: 8px !important;
  box-shadow: none !important;
  display: flex !important;
  flex-direction: column !important;
  justify-content: center !important;
  transition: border-color 0.15s ease, background-color 0.15s ease, transform 0.15s ease !important;
}
.service-card:hover {
  border-color: var(--border-strong) !important;
  background-color: var(--panel-hover) !important;
  transform: translateY(-1px);
  box-shadow: 0 8px 20px -14px var(--glow) !important;
}

/* shrink icon + text denser */
.service-card img,
.service-card .service-icon,
.service-card svg {
  width: 28px !important;
  height: 28px !important;
  max-width: 28px !important;
  max-height: 28px !important;
}
.service-title {
  padding: 0.15rem 0 !important;
  align-items: center !important;
}
.service-name {
  color: var(--text) !important;
  font-family: var(--mono) !important;
  font-weight: 600 !important;
  font-size: 0.78rem !important;
  line-height: 1.15 !important;
}
.service-description,
.service-tagline {
  color: var(--muted) !important;
  font-family: var(--mono) !important;
  font-size: 0.62rem !important;
  line-height: 1.2 !important;
  margin-top: 0.1rem !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

/* hide bulky container stats expansion area */
.service-stats {
  display: none !important;
}

.service-tags .badge,
.badge,
.status-tag {
  font-family: var(--mono) !important;
  font-size: 0.55rem !important;
  letter-spacing: 0.04em !important;
  text-transform: uppercase !important;
  border-radius: 3px !important;
  border: 1px solid rgba(43, 255, 156, 0.2) !important;
  background: rgba(43, 255, 156, 0.08) !important;
  color: var(--accent) !important;
  padding: 0 4px !important;
}

.bg-theme-100,
.bg-theme-200,
.bg-theme-300,
.dark\:bg-white\/5,
.dark\:bg-white\/10,
.shadow-md {
  background-color: transparent !important;
  box-shadow: none !important;
}

#footer {
  display: none !important;
}

@media (max-width: 1100px) {
  .services-list {
    grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
  }
}
@media (max-width: 800px) {
  .services-list {
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
  }
}
@media (max-height: 700px) {
  .service-description,
  .service-tagline {
    display: none !important;
  }
  .information-widget,
  #widgets-wrap > div {
    transform: scale(0.85);
  }
}
