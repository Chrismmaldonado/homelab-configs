# Caddy reverse proxy for the homelab.
# TLS via Cloudflare DNS-01 (CF_API_TOKEN in Caddy's environment).
# Replace example.com with your domain. Access log feeds CrowdSec.
{
	email admin@example.com
	log {
		output file /var/log/caddy/access.log {
			roll_size 20mb
			roll_keep 5
		}
		format json
	}
}

(cf) {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
	header {
		Strict-Transport-Security max-age=31536000;
		Referrer-Policy no-referrer
	}
}

home.example.com {
	import cf
	reverse_proxy 127.0.0.1:3001
}

adguard.example.com {
	import cf
	reverse_proxy 127.0.0.1:3000
}

uptime.example.com {
	import cf
	reverse_proxy 127.0.0.1:3002
}

logs.example.com {
	import cf
	reverse_proxy 127.0.0.1:3003
}

beszel.example.com {
	import cf
	reverse_proxy 127.0.0.1:3004
}

search.example.com {
	import cf
	reverse_proxy 127.0.0.1:3006
}

ntfy.example.com {
	import cf
	reverse_proxy 127.0.0.1:3007
}

paperless.example.com {
	import cf
	encode gzip
	reverse_proxy 127.0.0.1:8010
}

cloud.example.com {
	import cf
	encode gzip
	reverse_proxy 127.0.0.1:8088
}

# Wazuh dashboard uses self-signed TLS on the backend.
wazuh.example.com {
	import cf
	encode gzip
	reverse_proxy https://127.0.0.1:5601 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}

# DNS-over-HTTPS endpoint (AdGuard Home backend).
dns.example.com {
	import cf
	handle /dns-query* {
		reverse_proxy https://127.0.0.1:8443 {
			transport http {
				tls_server_name dns.example.com
			}
		}
	}
	handle {
		respond "DoH endpoint. Use /dns-query" 200
	}
}

# Static status pages for services with no web UI (generated by
# scripts/status-pages/refresh.sh, mounted read-only at /srv/status).
proxy.example.com {
	import cf
	encode gzip
	root * /srv/status/caddy
	file_server
}

crowdsec.example.com {
	import cf
	encode gzip
	root * /srv/status/crowdsec
	file_server
}
