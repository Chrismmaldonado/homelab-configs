{
	email admin@example.com
	log {
		output file /var/log/caddy/access.log {
			roll_size 20mb
			roll_keep 5
		}
		format json
	}
}

(cf) {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
	header {
		Strict-Transport-Security max-age=31536000;
		Referrer-Policy no-referrer
	}
}

home.dobasmp.net {
	import cf
	reverse_proxy 127.0.0.1:3001
}
adguard.dobasmp.net {
	import cf
	reverse_proxy 127.0.0.1:3000
}
map.dobasmp.net {
	import cf
	reverse_proxy 127.0.0.1:8100
}
dns.dobasmp.net {
	import cf
	handle /dns-query* {
		reverse_proxy https://127.0.0.1:8443 {
			transport http {
				tls_server_name dns.dobasmp.net
			}
		}
	}
	handle {
		respond "DoH endpoint. Use /dns-query" 200
	}
}
search.dobasmp.net {
	import cf
	reverse_proxy 127.0.0.1:3006
}

ntfy.dobasmp.net {
	import cf
	reverse_proxy 127.0.0.1:3007
}

paperless.dobasmp.net {
	import cf
	encode gzip
	reverse_proxy 127.0.0.1:8010
}

wazuh.dobasmp.net {
	import cf
	encode gzip
	reverse_proxy https://127.0.0.1:5601 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}

cloud.dobasmp.net {
	import cf
	encode gzip
	reverse_proxy 127.0.0.1:8088
}

proxy.dobasmp.net {
	import cf
	encode gzip
	root * /srv/status/caddy
	file_server
}

crowdsec.dobasmp.net {
	import cf
	encode gzip
	root * /srv/status/crowdsec
	file_server
}

monitor.dobasmp.net {
	import cf
	encode gzip
	reverse_proxy 127.0.0.1:3020
}

# Webmail via Cloudflare Tunnel (cloudflared-mail) and/or LAN Caddy.
# IMAP/SMTP clients use mx.dobasmp.net (DNS-only A -> WAN), not this host.
mail.dobasmp.net {
	import cf
	encode gzip
	handle /chris.mobileconfig {
		reverse_proxy 127.0.0.1:3017
	}
	handle /chris-wg.conf {
		reverse_proxy 127.0.0.1:3017
	}
	reverse_proxy 127.0.0.1:3016
}
